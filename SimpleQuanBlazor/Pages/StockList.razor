@page "/stocks"
@using SimpleQuanBlazor.Data
@inject StockService StockService

<PageTitle>A股成交额前100</PageTitle>

<h1>A股成交额前100名</h1>

<p>实时统计当前成交额前100的个股 (单位：亿元)。接口仅支持实时数据及最近一交易日统计。点击列名可进行排序。</p>

<div class="mb-3 d-flex align-items-center">
    <label for="refreshInterval" class="me-2">刷新频率:</label>
    <select id="refreshInterval" class="form-select w-auto" @onchange="OnIntervalChange">
        <option value="1000">1秒</option>
        <option value="2000">2秒</option>
        <option value="3000">3秒</option>
        <option value="5000">5秒</option>
        <option value="10000">10秒</option>
        <option value="0">停止刷新</option>
    </select>
    @if (refreshInterval > 0)
    {
        <span class="ms-3 text-muted">下次刷新预计在: @nextRefreshCounter 秒后</span>
    }
</div>

@if (loading && stocks == null)
{
    <p><em>Loading...</em></p>
}
else if (stocks == null || !stocks.Any())
{
    <p><em>未找到相关数据。</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("Code", e.ShiftKey))">代码 @GetSortIcon("Code")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("Name", e.ShiftKey))">名称 @GetSortIcon("Name")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("Price", e.ShiftKey))">最新价 @GetSortIcon("Price")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("ChangePercent", e.ShiftKey))">涨跌幅(%) @GetSortIcon("ChangePercent")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("Turnover", e.ShiftKey))">成交额 (亿) @GetSortIcon("Turnover")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("NetInflow", e.ShiftKey))">主力净流入 (亿) @GetSortIcon("NetInflow")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("TotalMarketCap", e.ShiftKey))">总市值 (亿) @GetSortIcon("TotalMarketCap")</th>
                <th style="cursor:pointer" @onclick="@((e) => ToggleSort("FloatMarketCap", e.ShiftKey))">流通市值 (亿) @GetSortIcon("FloatMarketCap")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stock in stocks)
            {
                <tr>
                    <td>@stock.Code</td>
                    <td>
                        <a href="https://quote.eastmoney.com/@(GetMarketPrefix(stock.Code)).html" target="_blank" class="text-decoration-none">
                            @stock.Name
                        </a>
                    </td>
                    <td>@stock.Price.ToString("F2")</td>
                    <td style="color: @(stock.ChangePercent >= 0 ? "red" : "green")">
                        @stock.ChangePercent.ToString("F2")%
                    </td>
                    <td>@((stock.Turnover / 100000000).ToString("F2"))</td>
                    <td style="color: @(stock.NetInflow >= 0 ? "red" : "green")">
                        @((stock.NetInflow / 100000000).ToString("F2"))
                    </td>
                    <td>@((stock.TotalMarketCap / 100000000).ToString("F2"))</td>
                    <td>@((stock.FloatMarketCap / 100000000).ToString("F2"))</td>
                </tr>
            }
        </tbody>
    </table>
}

@implements IDisposable

@code {
    private List<StockInfo>? stocks;
    private List<SortCriterion> sortCriteria = new() { new SortCriterion { Column = "Turnover", IsAscending = false } };
    private bool loading = false;
    private System.Timers.Timer? refreshTimer;
    private int refreshInterval = 1000; // 1秒
    private int nextRefreshCounter = 1;

    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }

    private class SortCriterion
    {
        public string Column { get; set; } = "";
        public bool IsAscending { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        SetupTimer();
    }

    private void SetupTimer()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();

        if (refreshInterval > 0)
        {
            nextRefreshCounter = refreshInterval / 1000;
            refreshTimer = new System.Timers.Timer(1000);
            refreshTimer.Elapsed += async (sender, e) =>
            {
                nextRefreshCounter--;
                if (nextRefreshCounter <= 0)
                {
                    await InvokeAsync(LoadData);
                }
                else
                {
                    await InvokeAsync(StateHasChanged);
                }
            };
            refreshTimer.AutoReset = true;
            refreshTimer.Enabled = true;
        }
    }

    private async Task OnIntervalChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newInterval))
        {
            refreshInterval = newInterval;
            SetupTimer();
            if (refreshInterval > 0)
            {
                await LoadData();
            }
        }
    }

    private async Task LoadData()
    {
        loading = true;
        stocks = await StockService.GetTop100ByTurnoverAsync();
        ApplySorting();
        loading = false;
        nextRefreshCounter = refreshInterval / 1000;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleSort(string column, bool multiSort)
    {
        var existing = sortCriteria.FirstOrDefault(x => x.Column == column);

        if (!multiSort)
        {
            // 单列排序：重置并应用新排序列
            bool nextAsc = (existing != null && sortCriteria.Count == 1) ? !existing.IsAscending : false; 
            sortCriteria.Clear();
            sortCriteria.Add(new SortCriterion { Column = column, IsAscending = nextAsc });
        }
        else
        {
            // 多列叠加：保留之前的顺序，将新列按点击顺序追加到末尾（或切换已有列方向）
            if (existing != null)
            {
                existing.IsAscending = !existing.IsAscending;
            }
            else
            {
                sortCriteria.Add(new SortCriterion { Column = column, IsAscending = false });
            }
        }
        ApplySorting();
    }

    private void ApplySorting()
    {
        if (stocks == null || !sortCriteria.Any()) return;

        IOrderedEnumerable<StockInfo>? query = null;

        for (int i = 0; i < sortCriteria.Count; i++)
        {
            var crit = sortCriteria[i];
            Func<StockInfo, object> selector = crit.Column switch
            {
                "Code" => s => s.Code,
                "Name" => s => s.Name,
                "Price" => s => s.Price,
                "ChangePercent" => s => s.ChangePercent,
                "Turnover" => s => s.Turnover,
                "NetInflow" => s => s.NetInflow,
                "TotalMarketCap" => s => s.TotalMarketCap,
                "FloatMarketCap" => s => s.FloatMarketCap,
                _ => s => s.Turnover
            };

            if (i == 0)
            {
                query = crit.IsAscending ? stocks.OrderBy(selector) : stocks.OrderByDescending(selector);
            }
            else
            {
                query = crit.IsAscending ? query!.ThenBy(selector) : query!.ThenByDescending(selector);
            }
        }

        stocks = query?.ToList();
    }

    private string GetMarketPrefix(string code)
    {
        if (string.IsNullOrEmpty(code)) return "";
        // 简单逻辑：6开头为上海(sh)，0或3开头为深圳(sz)，8或4开头为北京(bj)
        if (code.StartsWith("6")) return "sh" + code;
        if (code.StartsWith("0") || code.StartsWith("3")) return "sz" + code;
        if (code.StartsWith("8") || code.StartsWith("4")) return "bj" + code;
        return code;
    }

    private string GetSortIcon(string column)
    {
        var crit = sortCriteria.FirstOrDefault(x => x.Column == column);
        if (crit == null) return "↕";
        
        string indexStr = sortCriteria.Count > 1 ? (sortCriteria.IndexOf(crit) + 1).ToString() : "";
        return (crit.IsAscending ? "↑" : "↓") + indexStr;
    }
}
