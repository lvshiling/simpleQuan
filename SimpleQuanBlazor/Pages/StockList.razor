@page "/stocks"
@using SimpleQuanBlazor.Data
@inject StockService StockService

<PageTitle>A股成交额前100</PageTitle>

<h1>A股成交额前100名</h1>

<p>实时统计当前成交额前100的个股 (单位：亿元)。接口仅支持实时数据及最近一交易日统计。点击列名可进行排序。</p>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (stocks == null || !stocks.Any())
{
    <p><em>未找到相关数据。</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th style="cursor:pointer" @onclick="@(() => SortBy("Code"))">代码 @GetSortIcon("Code")</th>
                <th style="cursor:pointer" @onclick="@(() => SortBy("Name"))">名称 @GetSortIcon("Name")</th>
                <th style="cursor:pointer" @onclick="@(() => SortBy("Price"))">最新价 @GetSortIcon("Price")</th>
                <th style="cursor:pointer" @onclick="@(() => SortBy("ChangePercent"))">涨跌幅(%) @GetSortIcon("ChangePercent")</th>
                <th style="cursor:pointer" @onclick="@(() => SortBy("Turnover"))">成交额 (亿) @GetSortIcon("Turnover")</th>
                <th style="cursor:pointer" @onclick="@(() => SortBy("NetInflow"))">主力净流入 (亿) @GetSortIcon("NetInflow")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stock in stocks)
            {
                <tr>
                    <td>@stock.Code</td>
                    <td>@stock.Name</td>
                    <td>@stock.Price.ToString("F2")</td>
                    <td style="color: @(stock.ChangePercent >= 0 ? "red" : "green")">
                        @stock.ChangePercent.ToString("F2")%
                    </td>
                    <td>@((stock.Turnover / 100000000).ToString("F2"))</td>
                    <td style="color: @(stock.NetInflow >= 0 ? "red" : "green")">
                        @((stock.NetInflow / 100000000).ToString("F2"))
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<StockInfo>? stocks;
    private string currentSortColumn = "Turnover";
    private bool isAscending = false;
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        stocks = await StockService.GetTop100ByTurnoverAsync();
        SortStocks();
        loading = false;
    }

    private void SortBy(string column)
    {
        if (currentSortColumn == column)
        {
            isAscending = !isAscending;
        }
        else
        {
            currentSortColumn = column;
            isAscending = true;
        }
        SortStocks();
    }

    private void SortStocks()
    {
        if (stocks == null) return;

        switch (currentSortColumn)
        {
            case "Code":
                stocks = isAscending ? stocks.OrderBy(s => s.Code).ToList() : stocks.OrderByDescending(s => s.Code).ToList();
                break;
            case "Name":
                stocks = isAscending ? stocks.OrderBy(s => s.Name).ToList() : stocks.OrderByDescending(s => s.Name).ToList();
                break;
            case "Price":
                stocks = isAscending ? stocks.OrderBy(s => s.Price).ToList() : stocks.OrderByDescending(s => s.Price).ToList();
                break;
            case "ChangePercent":
                stocks = isAscending ? stocks.OrderBy(s => s.ChangePercent).ToList() : stocks.OrderByDescending(s => s.ChangePercent).ToList();
                break;
            case "Turnover":
                stocks = isAscending ? stocks.OrderBy(s => s.Turnover).ToList() : stocks.OrderByDescending(s => s.Turnover).ToList();
                break;
            case "NetInflow":
                stocks = isAscending ? stocks.OrderBy(s => s.NetInflow).ToList() : stocks.OrderByDescending(s => s.NetInflow).ToList();
                break;
        }
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "↕";
        return isAscending ? "↑" : "↓";
    }
}
